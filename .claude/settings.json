  {
    "permissions": {
      "defaultMode": "auto",
      "allow": [
        "Bash(*)",
        "Read(*)",
        "Write(*)",
        "Edit(*)",
        "Glob(*)",
        "Grep(*)",
        "WebFetch(*)",
        "WebSearch(*)"
      ]
    },
    "outputStyle": "proactive",
    "skipDangerousModePermissionPrompt": true,
    "enableAllProjectMcpServers": true,
    "plansDirectory": ".claude/plans",
    "hooks": {
      "Stop": [
        {
          "hooks": [
            {
              "type": "command",
              "command": "git add .claude/plans/ 2>/dev/null; git diff --cached --quiet || git commit -m \"chore: save plan\"; exit 0",
              "statusMessage": "Committing plan..."
            }
          ]
        }
      ]
    }
  }
