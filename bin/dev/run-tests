#!/usr/bin/env sh

# Runs the test suite deterministically.
#
# System tests (test/system) launch a headless Chrome per Cuprite session.
# A previous interrupted run can leave one behind, competing for resources
# with the browser this run needs and crashing it, hanging the suite
# indefinitely. This script clears that stray state before handing off to
# `bin/rails test`, which is itself configured (see test/test_helper.rb) to
# run with a single worker so multiple system test sessions never launch
# Chrome concurrently — that parallel-worker behavior was the actual cause
# of the hang, not the dev server.
#
# Deliberately does NOT kill Puma processes here: that would also kill a
# `bin/dev/run-web`/`run-all` session you're using to work in the browser
# alongside the test run. Only headless Chrome (never started by the dev
# server) and the stale pidfile are cleared.
#
# See CLAUDE.md for the full story.

cd "$(dirname "$0")/../.."

pkill -f "Chrome Helper.*--headless" >/dev/null 2>&1
rm -f tmp/pids/server.pid

# `bin/rails test` alone excludes test/system; default to running
# everything, including system tests, unless specific paths are given.
if [ "$#" -eq 0 ]; then
  exec bin/rails test test/models test/jobs test/services test/controllers test/system
else
  exec bin/rails test "$@"
fi
